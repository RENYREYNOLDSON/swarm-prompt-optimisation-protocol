{
  "buildCommand": "cd src/frontend && npm install && npm run build",
  "outputDirectory": "src/frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@5.0.10",
      "maxDuration": 60,
      "excludeFiles": "{**/{__pycache__,tests,test,testing,docs,examples}/**,**/*.{pyc,pyi,h,hpp,c,cpp,md},numpy/{distutils,f2py,typing,_pyinstaller}/**,pydantic/v1/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
